<aside class="_sidebar_3cc7fe"><div class="_header_3cc7fe"><h3 data-testid="sidebar-heading">Edit Person</h3><button class="_closeBtn_3cc7fe" aria-label="Close" title="Close">×</button></div><div class="_form_3cc7fe"><div class="_field_3cc7fe"><label for="field-name">Name</label><input id="field-name" data-testid="field-name" value=" "></div><div class="_field_3cc7fe"><label for="field-role">Role</label><input id="field-role" data-testid="field-role" value=" "></div><div class="_field_3cc7fe"><label for="field-discipline">Discipline</label><input id="field-discipline" data-testid="field-discipline" value=" "></div><div class="_field_3cc7fe"><label for="field-team">Team</label><input id="field-team" data-testid="field-team" value=" "></div><div class="_field_3cc7fe"><label for="field-manager">Manager</label><select id="field-manager" data-testid="field-manager"><option value="">(No manager)</option></select></div><div class="_field_3cc7fe"><label for="field-pod">Pod</label><span class="_fieldHint_3cc7fe">Group people within a team — e.g. "Backend", "Frontend"</span><input id="field-pod" data-testid="field-pod" value=""></div><div class="_field_3cc7fe"><label for="field-status">Status<button class="_infoIcon_3cc7fe" aria-label="Show status descriptions">ℹ</button></label><select id="field-status" data-testid="field-status"><option value="Active">Active</option><option value="Open">Open</option><option value="Transfer In">Transfer In</option><option value="Transfer Out">Transfer Out</option><option value="Backfill">Backfill</option><option value="Planned">Planned</option></select></div><div class="_field_3cc7fe"><label for="field-employmentType">Employment Type</label><input id="field-employmentType" data-testid="field-employmentType" value="FTE"></div><div class="_field_3cc7fe"><label for="field-level">Level</label><input id="field-level" data-testid="field-level" min="0" type="number" value="0"></div><div class="_field_3cc7fe"><label for="field-otherTeams">Other Teams</label><input id="field-otherTeams" data-testid="field-otherTeams" value=""></div><div class="_field_3cc7fe"><label for="field-publicNote">Public Note</label><textarea id="field-publicNote" data-testid="field-publicNote" placeholder="Visible on the org chart" rows="3"></textarea></div><div class="_field_3cc7fe"><label for="field-privateNote">Private Note</label><textarea id="field-privateNote" data-testid="field-privateNote" placeholder="Only visible in this panel" rows="3"></textarea></div><div class="_field_3cc7fe"><label class="_checkboxLabel_3cc7fe"><span>Private</span><input data-testid="field-private" type="checkbox"></label><span class="_privateHint_3cc7fe">Hidden when private toggle is off</span></div></div><div class="_actions_3cc7fe"><button class="_saveBtn_3cc7fe " title="Save changes" aria-live="polite">Save</button><button class="_deleteBtn_3cc7fe" title="Delete this person">Delete</button></div></aside>