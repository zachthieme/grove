<div class="_sidebar_3cc7fe"><div class="_header_3cc7fe"><h3 data-testid="sidebar-heading">Edit Person</h3><button class="_closeBtn_3cc7fe" aria-label="Close">×</button></div><div class="_form_3cc7fe"><div class="_field_3cc7fe"><label>Name</label><input data-testid="field-name" value="Bob Jones"></div><div class="_field_3cc7fe"><label>Role</label><input data-testid="field-role" placeholder="" value="Engineer"></div><div class="_field_3cc7fe"><label>Discipline</label><input data-testid="field-discipline" placeholder="" value="Eng"></div><div class="_field_3cc7fe"><label>Team</label><input data-testid="field-team" placeholder="" value="Platform"></div><div class="_field_3cc7fe"><label>Manager</label><select data-testid="field-manager"><option value="">(No manager)</option><option value="a1">Alice Smith — Platform</option></select></div><div class="_field_3cc7fe"><label>Pod</label><input data-testid="field-pod" placeholder="" value=""></div><div class="_field_3cc7fe"><label>Status<button class="_infoIcon_3cc7fe" aria-label="Show status descriptions">ℹ</button></label><select data-testid="field-status"><option value="Active">Active</option><option value="Open">Open</option><option value="Pending Open">Pending Open</option><option value="Transfer In">Transfer In</option><option value="Transfer Out">Transfer Out</option><option value="Backfill">Backfill</option><option value="Planned">Planned</option></select></div><div class="_field_3cc7fe"><label>Employment Type</label><input data-testid="field-employmentType" placeholder="FTE" value="FTE"></div><div class="_field_3cc7fe"><label>Level</label><input data-testid="field-level" min="0" placeholder="" type="number" value="0"></div><div class="_field_3cc7fe"><label>Other Teams</label><input data-testid="field-otherTeams" placeholder="Comma-separated" value=""></div><div class="_field_3cc7fe"><label>Public Note</label><textarea data-testid="field-publicNote" placeholder="Visible on the org chart" rows="3"></textarea></div><div class="_field_3cc7fe"><label>Private Note</label><textarea data-testid="field-privateNote" placeholder="Only visible in this panel" rows="3"></textarea></div><div class="_field_3cc7fe"><label><span>Private</span><input data-testid="field-private" type="checkbox"></label><span>Hidden when private toggle is off</span></div><div class="_actions_3cc7fe"><button class="_saveBtn_3cc7fe">Save</button><button class="_deleteBtn_3cc7fe">Delete</button></div></div></div>